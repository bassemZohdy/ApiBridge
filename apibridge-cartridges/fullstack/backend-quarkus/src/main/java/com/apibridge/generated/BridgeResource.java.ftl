package com.apibridge.generated;

import jakarta.enterprise.context.ApplicationScoped;
import jakarta.inject.Inject;
import jakarta.ws.rs.*;
import jakarta.ws.rs.core.Context;
import jakarta.ws.rs.core.HttpHeaders;
import jakarta.ws.rs.core.MediaType;
import jakarta.ws.rs.core.Response;
import org.eclipse.microprofile.config.inject.ConfigProperty;

/**
 * JAX-RS resource generated by ApiBridge for service: ${id}
 * Base path: ${basePath}
 */
@Path("${basePath}")
@ApplicationScoped
@Consumes(MediaType.APPLICATION_JSON)
@Produces(MediaType.APPLICATION_JSON)
public class BridgeResource {

    /** When true, all traffic is rejected with 503. */
    @ConfigProperty(name = "BLOCK_TRAFFIC", defaultValue = "false")
    boolean blockTraffic;

    /** When true, endpoints return canned mock responses instead of proxying. */
    @ConfigProperty(name = "MOCK_MODE", defaultValue = "false")
    boolean mockMode;

    @Inject
    ProxyService proxyService;

    @Context
    HttpHeaders headers;

    <#list endpoints as endpoint>
    <#assign methodName = endpoint.path?replace("/", " ")?replace("-", " ")?trim?capitalize?replace(" ", "")?uncap_first>
    @${endpoint.method?upper_case}
    @Path("${endpoint.path}")
    public Response ${methodName}(String body) {
        if (blockTraffic) {
            return Response.status(503)
                    .entity("{\"error\":\"Service temporarily unavailable\"}")
                    .build();
        }
        if (mockMode) {
            return Response.ok(
                    "{\"status\":\"mock\",\"endpoint\":\"${endpoint.path}\",\"method\":\"${endpoint.method?upper_case}\"}"
            ).build();
        }
        return proxyService.forward("${endpoint.backendUrl}", "${endpoint.method?upper_case}", body, headers);
    }
    </#list>
}
